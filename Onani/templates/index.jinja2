{% set title = "" %}
{% set ogtitle = "Onani | Anime Image Board" %}
{% set ogdesc = "Onani is an image board where people share their favorite anime content. Browse through a collection of
high quality videos and pictures, no account required!" %}

{% extends "base.jinja2" %}

{% block content %}

<!-- Left panel/Tags -->
{% include "elements/tag_bar.jinja2" %}

<!-- Post thumbnails -->
<div id="posts-container">
    {% if first_post is not none %}
    <div class="index-hero-post" onclick="location.href='/posts/{{ first_post.id }}'">
        <div class="index-hero-image-overlay" style="background-image:url('{{ first_post.sample }}');">
            <div class="index-hero-text-container">
                <h1>{{ first_post.title }}</h1>
                <p>Uploaded by {{ first_post.uploader.username }}</p>
            </div>
        </div>
    </div>
    {% else %}
    {# <div class="index-hero-text-container">
        <h1>Welcome!</h1>
        <p>Looks like there are no posts yet, why don't you <a href="{{url_for('main.upload')}}">upload</a>the first
            one?
        </p>
    </div> #}
    <div class="index-hero-post" onclick="location.href='{{url_for('main.upload')}}'">
        <div class="index-hero-image-overlay"
            {#style="background-image:url('{{ url_for('static', filename='android-chrome-512x512.png') }}');" #}>
            <div class="index-hero-text-container">
                <h1>Welcome!</h1>
                <p>Looks like there are no posts yet, why don't you upload the first one?
            </div>
        </div>
    </div>
    {% endif %}

    {# <div class="onani-loading"> </div> #}

    <div class="index-post-group">
        <div class="post-group-header">
            <h2><i class="fa-solid fa-clock"></i>Latest</h2>
            <a href="/posts/">
                <h3>View all</h3> <i class="fa-solid fa-angles-right"></i></i>
            </a>
        </div>
        <div class="post-group-grid">
            {% for post in latest %}
            <div class="post-thumbnail-container" title="{{ post.title }}">
                <a href="/posts/{{ post.id }}"><img src="{{ post.thumbnail() }}" class="post-thumbnail"></a>
            </div>
            {% endfor %}
        </div>
    </div>

