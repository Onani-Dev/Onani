{% set title = "Post - " %}

{% if post.description %}
  {% set ogtitle = post.description  %}
{% else %}
  {% set ogtitle = "Post"  %}
{% endif %}

{% set ogdesc = "View on Onani." %}
{% set ogimage = post.files[0].url %}

{% extends "base.jinja2" %}

{% block meta %}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:image" content="/thumbnail/500x500{{ post.files[0].url }}">
{% endblock %}

{% block content %}
<!-- Left panel/Tags -->
{% include "elements/tag_bar.jinja2" %}

<div id="posts-container">
  <a href="{{ post.files[0].url }}"><img class="main-image" src="{{ post.files[0].url }}"></a>
  <table>
    <tr>
    	<th>Uploaded At</th>
        <td>{{ post.uploaded_at }}</td>
    </tr>
    <tr>
    	<th>Status</th>
        <td>{{ post.status.name }}</td>
    </tr>
    <tr>
    	<th>Rating</th>
        <td>{{ post.rating.name }}</td>
    </tr>
    <tr>
    	<th>Source</th>
        <td><a href="{{ post.source }}">{{ post.source }}</a></td>
    </tr>
    <tr>
    	<th>Description</th>
        <td>{{ post.description }}</td>
    </tr>
    <tr>
    	<th>Uploader</th>
        <td><a href="{{ post.uploader }}">{{ post.uploader }}</a></td>
    </tr>
  </table>
</div>

{% endblock %}