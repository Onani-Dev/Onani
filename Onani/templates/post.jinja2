{% set title = "Post - " %}
{% set ogtitle = "{score}👍 | {comments}💬".format(score=post.score, comments=post.comments.all()|length) %}
{% set ogimage = post.files[0].thumbnail(500) %}

{% if post.description %}
  {% set ogdesc = post.description %}
{% else %}
  {% set ogdesc = "View on Onani." %}
{% endif %}

{% extends "base.jinja2" %}

{% block meta %}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:image" content="{{ post.files[0].thumbnail(500) }}">
{% endblock %}

{% block content %}
<!-- Left panel/Tags -->
{% include "elements/post_tag_bar.jinja2" %}

<div id="content-container">
  <script>
    const postID = {{ post.id }};
  </script>
  <div class="images-container">
    {% for file in post.files %}
      <div class="file-container">
        <a href="{{ file.url }}"><img class="main-image" src="{{ file.thumbnail(1000) }}"></a>
      </div>
    {% endfor %}
  </div>
  <div class="post-info-box">
    <div id="post-info-header">

      <div id="poster-container" style="background-color:{{ post.uploader.profile_colour }}">
        <img src="{{ post.uploader.get_avatar(size=30) }}" alt="{{ post.uploader.username }}" title="{{ post.uploader.username }}">
        <a href="/users/{{ post.uploader.id }}">{{ post.uploader.username }}</a>
      </div>

      <div id="voting-container">
        <div id="upvote-button" class="fa-solid fa-thumbs-up"></div>
        <div id="post-score-count">{{ post.score }}</div>
        <div id="downvote-button" class="fa-solid fa-thumbs-down"></div>
      </div>

    </div>

    <div id="post-info-body">
      <div id="description-container">
        {% if post.description %}
          {% set description = post.description %}
          {% set description_class = "" %}
        {% else %}
          {% set description = "Post has no description." %}
          {% set description_class = "system-text" %}
        {% endif %}
        <p class="{{ description_class }}">{{ description }}</p>
      </div>

      <div id="table-container">

        <table>
          <tr>
            <th>Uploaded At</th>
            <td class="date-format">{{ post.uploaded_at.isoformat() }}</td>
          </tr>
          <tr>
            <th>Status</th>
            <td>{{ post.status.name.capitalize() }}</td>
          </tr>
          <tr>
            <th>Rating</th>
            <td>{{ post.rating.name.capitalize() }}</td>
          </tr>
          <tr>
            <th>Source</th>
            <td>{% if post.source %}<a href="{{ '{source}?pid={pid}'.format(source=post.source, pid=post.id)  }}" target="_blank">{{ post.source }}</a>{% else %}No source available.{% endif %}</td>
          </tr>
        </table>

      </div>

    </div>
  </div>
  <div class="comments-box">
    <h1>Comments</h1>
    {% if not current_user.is_anonymous %}
      <div class="post-comment-input-container">
        <textarea id="post-comment-input" placeholder="Type your comment here..."></textarea>
        <button id="post-comment-submit">Post</button>
      </div>
    {% endif %}
    <div id="comment-container">
      Loading Comments...
    </div>
    <script src="/static/js/comments.min.js"></script>
  </div>
</div>
{# $(document).ready(function(){$('.images').slick({dots: true, infinite: false});}); #}
{% endblock %}