{% set title = "{name} - ".format(name=tag.humanized) %}
{% set ogtitle = tag.humanized %}
{% set ogdesc = tag.description %}
{# {% set ogimage = "/static/android-chrome-512x512.png" %} #}

{% extends "base.jinja2" %}

{% block content %}
<!-- Left panel/Tags -->
{% include "elements/tag_bar.jinja2" %}

<div id="content-container">
    <div id="news-article-header">
        <h1>{{ tag.humanized }}</h1>
    </div>
    <div id="news-article-body">
        <p>{{ tag.description }}</p>
    </div>
</div>

{% endblock %}