{% set title = "News - " %}
{% set ogtitle = article.title %}
{% set ogdesc = "View this {type} on Onani".format(type=article.type.name.capitalize()) %}

{% extends "base.jinja2" %}

{% block content %}

<div id="content-container">
    <div id="article-header">
        <h1 class="twemoji-format">{{ article.title }}</h1>
        <div class="date-format human-time">{{ article.created_at.isoformat() }}</div>
        <div>{{ article.type.name.capitalize() }} posted by <a href="/users/{{ article.author.id }}"
                alt="{{ article.author.username }}">{{ article.author.username }}</a></div>
    </div>
    {{-'<div id="article-body"><p class="twemoji-format markdown-format">{}</p></div>'.format(article.content)-}}
</div>

{% include "elements/right_bar.jinja2" %}
{% endblock %}