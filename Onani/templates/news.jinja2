{% set title = "News - " %}
{% set ogtitle = "News" %}
{% set ogdesc = "Latest Onani news." %}
{% set ogimage = "/static/android-chrome-512x512.png" %}

{% extends "base.jinja2" %}

{% block content %}
<!-- Left pannel/Tags -->
{% include "elements/tag_bar.jinja2" %}

<div id="outlined-container" class="grid-container">
  {% for news in news.items %}
    <div class="grid-item">
      <img src="/static/android-chrome-512x512.png" class="pfp-list">
      <a href="/news/{{ news.id }}">{{ news.title }}<h6>{{ news.content[:15] }}{{'...' if news.content|length > 15 else ''}}</h6></a>
    </div>
  {% endfor %}
  {% set pagination = news %}
  {% set page_url = "/news/" %}
  {% include "elements/pagination.jinja2" %}
</div>
{% endblock %}