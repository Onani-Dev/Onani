{% set title = "Users - " %}
{% set ogtitle = "Users" %}
{% set ogdesc = "A list of users on the best site. No idea if this complies with GDPR." %}
{% set ogimage = "../static/android-chrome-512x512.png" %}

{% extends "base.jinja2" %}

{% block content %}
<!-- Left pannel/Tags -->
{% include "elements/tag_bar.jinja2" %}
<!-- Right pannel/News -->
{% include "elements/right_bar.jinja2" %}


<div id="outlined-container" class="grid-container">
  {% for user in users.items %}
    <div class="grid-item"><img src="{{ user.settings.avatar }}" class="pfp-list"><a href="/users/{{ user.id }}" alt="{{ user.username }}">{{ user.username }}<h6>({{ user.role.name }} | {{ user.post_count }} posts)</h6></a></div>
  {% endfor %}
  <div class="page-navigation">
    {% if users.has_prev %}
      <a class="fa-solid fa-chevron-left" href="/users/?p={{ users.prev_num }}"></a>
    {% endif %}
    {% for page in users.iter_pages() %}
      {% if page %}
        {% if page == users.page %}
          <a href="/users/?p={{ page }}" style="text-decoration: underline;">{{ page }}</a>
        {% else %}
          <a href="/users/?p={{ page }}">{{ page }}</a>
        {% endif %}
      {% else %}
        ...
      {% endif %}
    {% endfor %}
    {% if users.has_next %}
      <a class="fa-solid fa-chevron-right" href="/users/?p={{ users.next_num }}"></a>
    {% endif %}
  </div>
</div>
{% endblock %}