{% set title = "Login - " %}
{% extends "base.jinja2" %}

{% block content %}
{% with messages = get_flashed_messages() %}
  {% if messages %}
    {% for message in messages %}
    <div class="flash-message">{{ message }}</div>
    {% endfor %}
  {% endif %}
{% endwith %}
<!-- Login box -->
<div class="login-box">
  <h1 class="login-bloody-header">Login</h1>
  <!-- Form -->
  <form action="/login/" method="POST">
    {{ form.csrf_token }}
    {{ form.username(placeholder="Username", autocapitalize="off") }}
    {{ form.password(placeholder="Password", autocomplete="off") }}
    <input id="submit" type="submit" value="Login">
  </form>
</div>
{% endblock %}