{% extends "base.html.jinja2" %}
{% block title %}Posts{% endblock %}

{% block content %}
<!-- Left pannel/Tags -->
<div id="left-pannel">
  <h2>Tags</h2>
  {% for tag in tags %}
  <li><a href="/posts?tags={{ tag.string }}"
      class="tag-list-item {{ tag.type.string.lower() }}">{{ tag.string[:20] }}{{'...' if tag.string|length > 20 else ''}}
      {{ tag.post_count }}</a></li>
  {% endfor %}
</div>
<!-- News and chat -->
<div id="right-pannel">

  <div id="newsbox">
    <div style="padding: 0px 0px 10px 0px;">
      <i class="fa fa-newspaper-o fa-2x" aria-hidden="true"></i>
      <h1 style="display: inline; padding: 10px">News</h1>
    </div>
    <div id="news-container">
      <li><a href="/news/1">Onani acquired by Titter!</a></li>
      <li><a href="/news/2">Official Onani IRC server!</a></li>
      <li><a href="/news/3">Fatass don-chan in a Tuxedo, wtf??!</a></li>
    </div>
  </div>

  <div id="chatbox">
    <div style="padding: 0px 0px 10px 0px;">
      <i class="fa fa-comment-o fa-2x" aria-hidden="true"></i>
      <h1 style="display: inline; padding: 10px">Chat</h1>
    </div>
    <div id="chat-container">
      {% if current_user.is_authenticated %}
      <script src="/javascript/onani-chat.min.js"></script>
      {% endif %}
      <div id="chat-message-area"></div>
      <div id="chat-message-input-container">
        <input type="text" name="chat-box-textarea" id="chat-box-textarea" placeholder="Please login to send messages.">
        <i class="fa fa-chevron-circle-right fa-2x" aria-hidden="true" id="chat-box-send"></i>
      </div>
    </div>

  </div>
</div>
{% endblock %}