{
	auto_https off
}

:80 {
	# Serve Vue SPA from /frontend/dist
	root * /frontend/dist

	# Route API and media traffic to Flask before SPA rewrite logic.
	@backend path /api* /images* /avatars* /videos* /static*
	handle @backend {
		reverse_proxy localhost:8000
	}

	# SPA catch-all: serve index.html for unknown routes.
	handle {
		try_files {path} /index.html
		file_server
	}
}
