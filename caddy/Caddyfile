{
	auto_https off
}

:80 {
	# Serve Vue SPA from /frontend/dist
	root * /frontend/dist

	# Route API traffic to Flask before SPA rewrite logic.
	@api path /api*
	handle @api {
		reverse_proxy localhost:8000
	}

	# SPA catch-all: serve index.html for unknown routes.
	handle {
		try_files {path} /index.html
		file_server
	}
}
