# Container Image
FROM python:3.10-alpine

ARG INSTALL_ML=false

# Environment variables
ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1

# Install the shit required to install pip requirements
RUN apk add --update --no-cache --virtual .tmp-build-deps gcc libc-dev \
    && apk add libffi-dev

# FFmpeg for transcoding videos
RUN apk add --no-cache ffmpeg

# Install requirements (optional ML extras controlled by build arg)
COPY requirements.txt requirements-ml.txt /
RUN pip3 install -r /requirements.txt \
    && if [ "$INSTALL_ML" = "true" ]; then pip3 install -r /requirements-ml.txt; fi

# Copy static folder
COPY ./frontend/public/static /static

# Copy working dir to root of virtual drive
COPY . /onani

RUN chmod +x /onani/celery/entrypoint.sh

# Set workdir
WORKDIR /onani

# Load entrypoint
ENTRYPOINT ["./celery/entrypoint.sh"]