# Container Image
FROM python:3.10-slim

ARG INSTALL_ML=false

# Environment variables
ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1

# Install build deps and FFmpeg
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libffi-dev ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Install requirements (optional ML extras controlled by build arg)
COPY requirements.txt requirements-ml.txt /
RUN pip3 install -r /requirements.txt \
    && if [ "$INSTALL_ML" = "true" ]; then pip3 install -r /requirements-ml.txt; fi

# Copy static folder
COPY ./frontend/public/static /static

# Copy working dir to root of virtual drive
COPY . /onani

RUN chmod +x /onani/celery/entrypoint.dev.sh

# Set workdir
WORKDIR /onani

# Load entrypoint
ENTRYPOINT ["./celery/entrypoint.dev.sh"]